---
import "@fontsource/rubik/400.css";
import "@fontsource/rubik/500.css";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/700.css";
import "../styles/global.css";
import { Image } from "astro:assets";
import logo from "../assets/chasqui-logo.svg";
import inboxShot from "../assets/inbox.png";
import conversationShot from "../assets/conversation.png";
import dashboardShot from "../assets/dashboard-dark.png";

const GITHUB = "https://github.com/chasqui-stack/chasqui";
const TITLE = "Chasqui — open-source stack for AI chat agents";
const DESCRIPTION =
  "Build custom AI chat agents you actually own: LangGraph orchestrator, memory, FAQ RAG, multimodal, human handoff inbox and a pluggable tool system. Self-hosted, channel-agnostic. WhatsApp today, more channels on the roadmap.";

const features = [
  {
    title: "Conversation engine",
    body: "A LangGraph orchestrator keeps one continuous thread per contact — context, silence handling and delivery errors are already solved.",
  },
  {
    title: "Memory + FAQ RAG",
    body: "Long-term memory and a grounded FAQ knowledge base on Postgres + pgvector. Answers cite your content, not hallucinations.",
  },
  {
    title: "Multimodal, both ways",
    body: "Images, documents and voice notes — understood on the way in, sent on the way out.",
  },
  {
    title: "Human handoff inbox",
    body: "The agent detects when a person is needed; operators take over and reply from the panel, media included.",
  },
  {
    title: "Tool Modules",
    body: "Self-contained packages the core auto-discovers: tools, tables, routes and config forms the panel renders for free.",
  },
  {
    title: "Any LLM, a .env swap",
    body: "Gemini, Claude, GPT, OpenRouter or local Ollama. Change provider and the next message uses it — no redeploy.",
  },
];

const roadmap = [
  { title: "Telegram channel", detail: "a second gateway speaking the same contract" },
  { title: "Web chat widget", detail: "embeddable channel for any website" },
  { title: "Analytics", detail: "conversation stats module for the panel" },
  { title: "Document RAG", detail: "knowledge base beyond FAQ pairs — PDFs, docs" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://chasqui.chat/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content="https://chasqui.chat/" />
    <meta property="og:image" content="https://chasqui.chat/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>

  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a href="/" aria-label="Chasqui home">
          <Image src={logo} alt="Chasqui" height={36} class="nav-logo" />
        </a>
        <nav class="nav-links">
          <a href="#features">Features</a>
          <a href="#architecture">Architecture</a>
          <a href="#quickstart">Quickstart</a>
          <a href="#roadmap">Roadmap</a>
          <a class="btn btn-amber nav-cta" href={GITHUB}>GitHub</a>
        </nav>
      </div>
    </header>

    <section class="hero">
      <div class="container">
        <h1>
          Build AI chat agents<br />you actually <span class="accent">own</span>.
        </h1>
        <p class="hero-sub">
          Chasqui is an open-source, self-hosted stack for custom AI chat
          agents: conversation engine, memory, RAG, human handoff and a
          pluggable tool system — wired and ready, so your energy goes into
          your agent's logic. <strong>WhatsApp today, more channels on the
          roadmap.</strong>
        </p>

        <div class="terminal" id="install">
          <span class="terminal-dollar">$</span>
          <code id="install-cmd">uvx chasqui new my-agent</code>
          <button class="copy-btn" data-copy="uvx chasqui new my-agent" aria-label="Copy command">copy</button>
        </div>

        <div class="hero-ctas">
          <a class="btn btn-amber" href={GITHUB}>Get started →</a>
          <a class="btn btn-outline" href={GITHUB}>★ Star on GitHub</a>
        </div>

        <p class="hero-note">Apache-2.0 · beta · one command scaffolds and provisions the whole stack</p>
      </div>

      <div class="container hero-shot-wrap">
        <Image src={inboxShot} alt="Chasqui operator panel: a human-handoff conversation with image and voice messages" class="hero-shot" widths={[760, 1520]} sizes="(max-width: 800px) 100vw, 1032px" />
      </div>
    </section>

    <section class="section" id="features">
      <div class="container">
        <span class="eyebrow">Batteries included</span>
        <h2 class="section-title">Everything an agent needs, already wired</h2>
        <p class="section-lead">
          The plumbing decisions are made — Postgres + pgvector, one canonical
          message contract, conventions over configuration. You build what
          makes your agent different.
        </p>
        <div class="grid">
          {
            features.map((f) => (
              <div class="card">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-alt" id="architecture">
      <div class="container">
        <span class="eyebrow">Channel-agnostic by design</span>
        <h2 class="section-title">The core never knows a channel exists</h2>
        <p class="section-lead">
          Channels are thin, stateless gateways that translate their platform
          to one canonical contract — two endpoints and you've added a
          channel. Handoff, media, silence and delivery errors are expressed
          once, inherited by every channel for free.
        </p>

        <div class="diagram" role="img" aria-label="Architecture: channel gateways talk to the core through one canonical contract; the core uses Postgres with pgvector and is operated through the admin panel">
          <div class="diagram-col">
            <div class="diagram-box channel">WhatsApp<br /><small>PyWa gateway · live</small></div>
            <div class="diagram-box channel dashed">Telegram<br /><small>roadmap</small></div>
            <div class="diagram-box channel dashed">Web widget<br /><small>roadmap</small></div>
          </div>
          <div class="diagram-contract">
            <span>one canonical contract</span>
            <code>/ingest · /send</code>
            <div class="diagram-arrow">⟷</div>
          </div>
          <div class="diagram-col">
            <div class="diagram-box core">
              core<br /><small>FastAPI + LangGraph<br />agent · memory · RAG · tools · handoff</small>
            </div>
            <div class="diagram-box store">Postgres + pgvector</div>
            <div class="diagram-box admin-box">admin panel<br /><small>React SPA · REST · JWT</small></div>
          </div>
        </div>

        <p class="section-foot">
          Every non-obvious decision is written down as an ADR —
          <a href="https://github.com/chasqui-stack/chasqui/blob/main/docs/ARCHITECTURE.md">read the architecture</a>.
        </p>
      </div>
    </section>

    <section class="section" id="panel">
      <div class="container panel-grid">
        <div>
          <span class="eyebrow">Operator panel</span>
          <h2 class="section-title">Run the agent without touching code</h2>
          <ul class="checklist">
            <li>Edit the system prompt and watch behavior change on the next message</li>
            <li>Curate the FAQ knowledge base that grounds RAG answers</li>
            <li>Configure tool modules through auto-rendered forms</li>
            <li>Watch conversations live, take over when it matters</li>
            <li>Capture and review leads</li>
          </ul>
        </div>
        <div class="panel-shots">
          <Image src={dashboardShot} alt="Chasqui admin dashboard in dark mode" class="shot" widths={[520, 1040]} sizes="(max-width: 800px) 100vw, 520px" />
          <Image src={conversationShot} alt="A full conversation: AI replies, human handoff, operator takeover" class="shot" widths={[520, 1040]} sizes="(max-width: 800px) 100vw, 520px" />
        </div>
      </div>
    </section>

    <section class="section quickstart" id="quickstart">
      <div class="container">
        <span class="eyebrow eyebrow-amber">Quickstart</span>
        <h2 class="section-title">From zero to a running agent</h2>
        <div class="steps">
          <div class="step">
            <div class="step-n">1</div>
            <h3>Scaffold</h3>
            <pre><code>uvx chasqui new my-agent</code></pre>
            <p>The wizard asks: LLM, embeddings, Postgres, ports, WhatsApp credentials (skippable), language, first admin — then provisions deps, database and migrations.</p>
          </div>
          <div class="step">
            <div class="step-n">2</div>
            <h3>Run</h3>
            <pre><code>cd core && make dev
cd whatsapp && make dev
cd admin && npm run dev</code></pre>
            <p>API, WhatsApp gateway and operator panel — each a one-liner.</p>
          </div>
          <div class="step">
            <div class="step-n">3</div>
            <h3>Connect WhatsApp</h3>
            <pre><code>docs/WHATSAPP-SETUP.md</code></pre>
            <p>A free Meta developer app is enough to start. Step-by-step guide included, ngrok webhook auto-registration in dev.</p>
          </div>
        </div>
        <p class="section-foot quickstart-foot">
          Prerequisites: <a href="https://docs.astral.sh/uv/">uv</a>, Node 22, PostgreSQL with pgvector (or the generated docker-compose).
        </p>
      </div>
    </section>

    <section class="section" id="roadmap">
      <div class="container">
        <span class="eyebrow">Roadmap</span>
        <h2 class="section-title">Where this is going</h2>
        <div class="roadmap">
          {
            roadmap.map((r) => (
              <div class="roadmap-item">
                <strong>{r.title}</strong>
                <span>{r.detail}</span>
              </div>
            ))
          }
        </div>
        <p class="section-foot">
          Issues and ideas welcome — <a href={GITHUB}>join in on GitHub</a>.
        </p>
      </div>
    </section>

    <footer class="footer">
      <div class="container footer-inner">
        <p class="footer-lore">
          Named after the <em>chasqui</em> — the relay messengers of the Inca
          empire who carried messages across the network.
        </p>
        <nav class="footer-links">
          <a href={GITHUB}>GitHub</a>
          <a href="https://pypi.org/project/chasqui/">PyPI</a>
          <a href="https://github.com/chasqui-stack/chasqui/blob/main/docs/ARCHITECTURE.md">Architecture</a>
          <a href="https://github.com/chasqui-stack/chasqui/blob/main/LICENSE">Apache-2.0</a>
        </nav>
        <p class="footer-copy">© 2026 Chasqui contributors</p>
      </div>
    </footer>

    <script>
      document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(btn.dataset.copy ?? "");
          btn.textContent = "copied!";
          setTimeout(() => (btn.textContent = "copy"), 1600);
        });
      });
    </script>
  </body>
</html>

<style>
  /* ---- nav ---- */
  .nav {
    background: var(--charcoal);
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid rgba(239, 222, 196, 0.08);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    padding-bottom: 14px;
  }
  .nav-logo {
    display: block;
    height: 36px;
    width: auto;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 26px;
  }
  .nav-links a:not(.nav-cta) {
    color: var(--cream-muted);
    text-decoration: none;
    font-size: 15px;
  }
  .nav-links a:not(.nav-cta):hover {
    color: var(--cream);
  }
  .nav-cta {
    padding: 8px 16px;
    font-size: 15px;
  }
  @media (max-width: 720px) {
    .nav-links a:not(.nav-cta) {
      display: none;
    }
  }

  /* ---- hero ---- */
  .hero {
    background: var(--charcoal);
    color: var(--cream);
    padding: 96px 0 0;
    overflow: hidden;
  }
  .hero h1 {
    font-size: clamp(38px, 6vw, 64px);
    font-weight: 700;
    color: #f7f1e5;
  }
  .accent {
    color: var(--amber);
  }
  .hero-sub {
    font-size: 20px;
    color: var(--cream-muted);
    max-width: 680px;
    margin: 24px 0 36px;
  }
  .hero-sub strong {
    color: var(--cream);
  }
  .terminal {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--charcoal-soft);
    border: 1px solid rgba(239, 222, 196, 0.15);
    border-radius: 12px;
    padding: 14px 18px;
    font-size: 17px;
  }
  .terminal-dollar {
    color: var(--amber);
    font-family: ui-monospace, monospace;
    font-weight: 700;
  }
  .terminal code {
    color: #f7f1e5;
    white-space: nowrap;
  }
  @media (max-width: 480px) {
    .terminal {
      font-size: 14px;
      gap: 8px;
      padding: 12px 14px;
    }
  }
  .copy-btn {
    background: none;
    border: 1px solid rgba(239, 222, 196, 0.25);
    border-radius: 6px;
    color: var(--cream-muted);
    font-size: 12px;
    padding: 4px 10px;
    cursor: pointer;
  }
  .copy-btn:hover {
    color: var(--cream);
    border-color: var(--cream);
  }
  .hero-ctas {
    display: flex;
    gap: 14px;
    margin-top: 32px;
    flex-wrap: wrap;
  }
  .hero-note {
    color: rgba(239, 222, 196, 0.5);
    font-size: 14px;
    margin-top: 22px;
  }
  .hero-shot-wrap {
    margin-top: 64px;
    margin-bottom: -2px;
  }
  .hero-shot {
    display: block;
    width: 100%;
    max-width: 1032px;
    height: auto;
    margin: 0 auto;
    border-radius: 14px 14px 0 0;
    border: 1px solid rgba(239, 222, 196, 0.18);
    border-bottom: none;
    box-shadow: 0 -10px 60px rgba(234, 155, 39, 0.12);
  }

  /* ---- features ---- */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 44px;
  }
  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
  .card {
    background: #fff;
    border: 1px solid #e7e0d2;
    border-radius: 14px;
    padding: 24px;
  }
  .card h3 {
    font-size: 19px;
    margin-bottom: 8px;
  }
  .card p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 15.5px;
  }

  /* ---- architecture ---- */
  .section-alt {
    background: var(--cream);
  }
  .diagram {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-top: 48px;
    flex-wrap: wrap;
  }
  .diagram-col {
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
    min-width: 220px;
  }
  .diagram-box {
    background: #fff;
    border: 1.5px solid var(--charcoal);
    border-radius: 12px;
    padding: 14px 18px;
    font-family: var(--font-display);
    font-weight: 500;
    text-align: center;
  }
  .diagram-box small {
    font-family: var(--font-body);
    font-weight: 400;
    color: var(--ink-muted);
  }
  .diagram-box.dashed {
    border-style: dashed;
    opacity: 0.65;
  }
  .diagram-box.core {
    background: var(--charcoal);
    color: #f7f1e5;
    border-color: var(--charcoal);
  }
  .diagram-box.core small {
    color: var(--cream-muted);
  }
  .diagram-box.store {
    border-color: var(--amber);
    background: rgba(234, 155, 39, 0.12);
  }
  .diagram-contract {
    text-align: center;
    font-size: 14px;
    color: var(--ink-muted);
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 170px;
  }
  .diagram-contract code {
    color: var(--terracotta);
    font-weight: 600;
  }
  .diagram-arrow {
    font-size: 28px;
    color: var(--charcoal);
  }
  .section-foot {
    margin-top: 36px;
    color: var(--ink-muted);
  }
  .section-foot a {
    color: var(--terracotta);
    font-weight: 500;
  }

  /* ---- panel ---- */
  .panel-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 860px) {
    .panel-grid {
      grid-template-columns: 1fr;
    }
  }
  .checklist {
    list-style: none;
    padding: 0;
    margin: 24px 0 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .checklist li {
    padding-left: 30px;
    position: relative;
    color: var(--ink-muted);
  }
  .checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    width: 20px;
    height: 20px;
    border-radius: 6px;
    background: var(--amber);
    color: var(--charcoal);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .panel-shots {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .shot {
    width: 100%;
    height: auto;
    border-radius: 12px;
    border: 1px solid #e7e0d2;
    box-shadow: 0 8px 30px rgba(28, 25, 23, 0.1);
  }

  /* ---- quickstart ---- */
  .quickstart {
    background: var(--charcoal);
    color: var(--cream);
  }
  .quickstart .section-title {
    color: #f7f1e5;
  }
  .eyebrow-amber {
    color: var(--amber);
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 44px;
  }
  @media (max-width: 860px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
  .step {
    background: var(--charcoal-soft);
    border: 1px solid rgba(239, 222, 196, 0.12);
    border-radius: 14px;
    padding: 26px;
  }
  .step-n {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--amber);
    color: var(--charcoal);
    font-family: var(--font-display);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .step h3 {
    font-size: 19px;
    color: #f7f1e5;
    margin-bottom: 12px;
  }
  .step pre {
    background: var(--charcoal);
    border: 1px solid rgba(239, 222, 196, 0.12);
    border-radius: 8px;
    padding: 12px 14px;
    overflow-x: auto;
    font-size: 13.5px;
    line-height: 1.5;
  }
  .step pre code {
    color: var(--cream);
  }
  .step p {
    color: var(--cream-muted);
    font-size: 14.5px;
    margin: 12px 0 0;
  }
  .quickstart-foot {
    color: var(--cream-muted);
  }
  .quickstart-foot a {
    color: var(--amber);
  }

  /* ---- roadmap ---- */
  .roadmap {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 40px;
  }
  @media (max-width: 700px) {
    .roadmap {
      grid-template-columns: 1fr;
    }
  }
  .roadmap-item {
    border: 1.5px dashed #d6c9ae;
    border-radius: 12px;
    padding: 18px 22px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .roadmap-item strong {
    font-family: var(--font-display);
  }
  .roadmap-item span {
    color: var(--ink-muted);
    font-size: 15px;
  }

  /* ---- footer ---- */
  .footer {
    background: var(--charcoal);
    color: var(--cream-muted);
    padding: 56px 0;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 22px;
    align-items: flex-start;
  }
  .footer-lore {
    max-width: 520px;
    margin: 0;
  }
  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-links a {
    color: var(--cream);
    text-decoration: none;
    font-size: 15px;
  }
  .footer-links a:hover {
    color: var(--amber);
  }
  .footer-copy {
    font-size: 13.5px;
    margin: 0;
    color: rgba(239, 222, 196, 0.45);
  }
</style>
